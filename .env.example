# Copy to `.env.local` for local dev. On Vercel, set the same keys in Project → Settings → Environment Variables.
# Never commit `.env.local`.

VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Optional: set user metadata key `sdd_role` to `APPROVER` in Supabase (Authentication → Users → user metadata)
# for approver UI. Otherwise users default to STAFF.
